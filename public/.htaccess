<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /gain-panel/

  # Don't rewrite existing files or directories (assets, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else falls back to the SPA shell
  RewriteRule . /gain-panel/index.html [L]
</IfModule>
